# Port the Vite dev server binds to. Default: 3000.
PORT=3000

# These will be automatically created by Neon Launchpad (https://neon.new).
# You will also need to
DATABASE_URL=
DATABASE_URL_POOLER=

# Clerk — required for admin mutations in production. clerkMiddleware
# (wired in src/start.ts) populates the request auth state on every
# request, and adminProcedure reads the signed-in user's primary email
# via @clerk/tanstack-react-start/server `auth()`. See docs/admin-auth.md.
#
# VITE_ prefix exposes the publishable key to the client bundle (required
# for Clerk's React components). The server also reads it as CLERK_PUBLISHABLE_KEY
# for middleware; set both to the same value.
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Comma-separated whitelist of emails allowed to call admin mutations.
# Empty in non-production: admin mutations are reachable without sign-in
# (dev convenience). Empty in production: all mutations rejected.
#
# For agent/e2e access in dev, include a Clerk test-mode email (any
# address containing +clerk_test is auto-verified by dev Clerk instances
# and always accepts OTP 424242). See docs/admin-auth.md.
ADMIN_EMAILS=analyst-agent+clerk_test@analyst.local
